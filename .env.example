# Admin panel — required for login and storage
# Generate ADMIN_PASSWORD_HASH: run in terminal: node -e "console.log(require('bcryptjs').hashSync('admin123', 10))"
ADMIN_EMAIL=thomas@devresse.fit
ADMIN_PASSWORD_HASH=<paste bcrypt hash here>
JWT_SECRET=<random string e.g. openssl rand -hex 32>

# Vercel Blob — required for uploads and saving content/products
# Create at: Vercel project → Storage → Blob → Create
BLOB_READ_WRITE_TOKEN=<from Vercel Blob>

# Stripe — required for e-commerce and booking payments
# Create at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_... (optional, for webhook signature verification)
